{
  "name": "waypoint-guest-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "../hosting-platform/packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run lint && bun run format:check && bun run check-types",
    "check-types": "bun run --filter='*' check-types",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix"
  },
  "dependencies": {
    "@waypoint/auth": "workspace:*",
    "@waypoint/backend": "workspace:*",
    "@waypoint/core": "workspace:*",
    "@waypoint/db": "workspace:*",
    "better-auth": "^1.5.0",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "@waypoint/cli": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "kysely": "0.28.17"
  },
  "packageManager": "bun@1.3.12"
}
