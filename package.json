{
  "name": "waypoint-guest-app",
  "private": true,
  "description": "Example app showing the ideal Waypoint hosting-platform shape with TanStack Start, Cloudflare Workers, Better Auth, D1, and typed API contracts.",
  "workspaces": [
    "apps/*",
    "../hosting-platform/packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run lint && bun run format:check && bun run check-types && bun run test",
    "check-types": "bun run --filter='@waypoint-guest-app/*' check-types",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "bun test"
  },
  "dependencies": {
    "@waypoint/auth": "workspace:*",
    "@waypoint/backend": "workspace:*",
    "@waypoint/core": "workspace:*",
    "@waypoint/db": "workspace:*",
    "better-auth": "1.6.11",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "@types/bun": "^1.3.14",
    "@waypoint/cli": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@better-auth/core": "1.6.11",
    "@better-auth/utils": "0.4.0",
    "kysely": "0.28.17"
  },
  "packageManager": "bun@1.3.12"
}
